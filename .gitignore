# Dependencies (নির্ভরতা) - এগুলো ভুলেও গিটহাবে দেবেন না
node_modules/
jspm_packages/

# Build outputs (তৈরি করা ফাইল) - এগুলো কোড থেকে অটো জেনারেট হয়
dist/
tmp/
out-tsc/
build/

# Firebase specific (ফায়ারবেস সম্পর্কিত)
# .firebase ফোল্ডারে আপনার লোকাল টোকেন থাকতে পারে, তাই এটি বাদ দেওয়া জরুরি
.firebase/
firebase-debug.log*
firestore-debug.log*
pubsub-debug.log*
ui-debug.log*
functions/node_modules/

# Environment Variables (গোপন চাবিকাঠি) - সবচেয়ে গুরুত্বপূর্ণ
# আপনার API Key, Database Password এই ফাইলগুলোতে থাকে
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# Logs (লগ ফাইল) - এগুলো সিস্টেমে তৈরি হয়
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# IDEs and Editors (এডিটর ফাইল) - এগুলো আপনার ব্যক্তিগত চয়েস
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS related (অপারেটিং সিস্টেমের ফাইল)
.DS_Store
Thumbs.db